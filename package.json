{
  "name": "iaf-implementation-hub",
  "version": "0.3.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "set DISABLE_RSPACK_INCREMENTAL=true&& docusaurus start",
    "prebuild": "node scripts/generate-hub-doc-context.mjs",
    "prestart": "node scripts/generate-hub-doc-context.mjs",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "ecfr:watch": "node scripts/ecfr-hub-relevance.mjs",
    "platform:api": "npm run dev --workspace @iaf/platform-api",
    "platform:web": "npm run dev --workspace @iaf/platform-web",
    "platform:check-policy": "npm run check --workspace @iaf/policy",
    "platform:check-connectors": "npm run test --workspace @iaf/connectors"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.0",
    "@docusaurus/faster": "^3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/tsconfig": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "@types/react": "^19.0.0",
    "typescript": "~6.0.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
